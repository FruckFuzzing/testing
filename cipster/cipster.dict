inst8="\x24"
attr8="\x30"
member8="\x28"

# Common object ids
identity_cls="\x01"
msg_router_cls="\x02"
assembly_cls="\x04"
conn_mgr_cls="\x06"
tcpip_cls="\xf5"
ethlink_cls="\xf6"

# Sample application assembly instances
